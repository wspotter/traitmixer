{
  "name": "traitmixer-server",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=../../.env --import tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=../../.env --import tsx src/server.ts",
    "uninstall-traits": "node --env-file=../../.env --import tsx src/uninstall.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "traitmixer-connectors": "workspace:*",
    "traitmixer-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.4"
  }
}
