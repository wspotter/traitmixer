# TraitMixer Server Port (default: 4400)
# TRAITMIXER_SERVER_PORT=4400
# Comma-separated list of browser origins allowed to call the API in deployed environments
# TRAITMIXER_ALLOWED_ORIGINS=https://traitmixer.example.com

# ── OpenClaw (file-based) ──
# Recommended: point at the active OpenClaw workspace directory.
# TraitMixer will resolve directory paths to SOUL.md automatically.
# TraitMixer only manages that workspace file; it does not rewrite ~/.openclaw/openclaw.json.
# TRAITMIXER_OPENCLAW_WORKSPACE_PATH=~/.openclaw/workspace
# Legacy alias still supported if you want to point at a specific bootstrap file:
# TRAITMIXER_OPENCLAW_CONFIG_PATH=~/.openclaw/workspace/SOUL.md

# ── Open WebUI (HTTP API) ──
# TRAITMIXER_OPENWEBUI_URL=http://localhost:3000
# TRAITMIXER_OPENWEBUI_API_KEY=your-api-key
# TRAITMIXER_OPENWEBUI_MODEL_ID=my-custom-model

# ── AnythingLLM (HTTP API) ──
# TRAITMIXER_ANYTHINGLLM_URL=http://localhost:3001
# TRAITMIXER_ANYTHINGLLM_API_KEY=your-api-key
# TRAITMIXER_ANYTHINGLLM_WORKSPACE=default

# ── Hermes Agent (file-based) ──
# Path to Hermes SOUL.md (default: ~/.hermes/SOUL.md)
# TRAITMIXER_HERMES_SOUL_PATH=~/.hermes/SOUL.md

# ── Agent Zero (file-based) ──
# Path to Agent Zero system prompt file
# TRAITMIXER_AGENTZERO_PROMPT_PATH=~/agent-zero/prompts/default/agent.system.md

# ── Claude Code (file-based) ──
# Path to Claude Code project memory file
# Relative paths are resolved from the repository root
# TRAITMIXER_CLAUDECODE_PATH=~/my-project/CLAUDE.md

# ── UI (Vite) ──
# Public API base URL used by the browser app.
# Set this for non-local deployments when the UI is not served from the same origin as the API.
# VITE_TRAITMIXER_API_URL=http://localhost:4400
