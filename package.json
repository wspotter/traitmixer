{
  "name": "traitmixer",
  "version": "0.1.0",
  "description": "Personality editor and compiler for AI assistants",
  "license": "MIT",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter traitmixer-ui dev & pnpm --filter traitmixer-server dev & wait",
    "dev:ui": "pnpm --filter traitmixer-ui dev",
    "dev:server": "pnpm --filter traitmixer-server dev",
    "build": "pnpm --filter traitmixer-ui build",
    "test": "pnpm -r test",
    "test:core": "pnpm --filter traitmixer-core test",
    "test:ui": "pnpm --filter traitmixer-ui test",
    "typecheck": "tsc -b",
    "uninstall-traits": "pnpm --filter traitmixer-server uninstall-traits"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
